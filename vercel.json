{
  "functions": {
    "api/chat.js": {
      "maxDuration": 60,
      "includeFiles": "data/dream_entries.json"
    },
    "api/save-response.js": {
      "maxDuration": 10
    },
    "api/conversations.js": {
      "maxDuration": 10
    },
    "api/messages.js": {
      "maxDuration": 10
    },
    "api/migrate-anon.js": {
      "maxDuration": 10
    },
    "api/config.js": {
      "maxDuration": 5
    }
  },
  "rewrites": [
    { "source": "/chat", "destination": "/chat.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/background.mp4",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(favicon.ico|icon.svg|icon-192.png|icon-512.png|apple-touch-icon.png|poster.jpg)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000" }
      ]
    }
  ]
}
